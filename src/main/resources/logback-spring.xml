<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
      CONSOLE appender — plaintext, used by CLI / indexing flows. The
      pipeline + UI scrape stdout for a few formatted lines and we don't
      want JSON noise leaking into a `codeiq index` invocation.
    -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%msg%n</pattern>
        </encoder>
    </appender>

    <!--
      JSON appender — used by the `serving` profile only. Emits one
      structured event per log entry: timestamp, level, logger, thread,
      message, MDC contents (request_id from RequestIdFilter), and a
      compact stack-trace block on errors. Designed for ingestion by
      Loki / Splunk / OpenSearch — k8s `kubectl logs` output stays
      machine-parseable. See LogstashEncoder docs for the field schema.

      We pin to logstash-logback-encoder 9.0 (pom.xml) — the appender's
      `customFields` line below adds a static `application` tag so logs
      from multiple codeiq pods are easy to filter.
    -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"application":"codeiq"}</customFields>
            <includeMdc>true</includeMdc>
            <fieldNames>
                <timestamp>ts</timestamp>
                <level>level</level>
                <logger>logger</logger>
                <thread>thread</thread>
                <message>msg</message>
                <stackTrace>stack</stackTrace>
            </fieldNames>
        </encoder>
    </appender>

    <!-- Suppress noisy third-party loggers -->
    <logger name="org.neo4j" level="ERROR" />
    <logger name="org.springframework.data.neo4j" level="ERROR" />
    <logger name="org.springframework.ai.mcp" level="OFF" />
    <logger name="org.springframework.boot" level="ERROR" />
    <logger name="org.springframework.core.env" level="ERROR" />
    <logger name="org.springframework.web" level="WARN" />
    <logger name="io.netty" level="ERROR" />
    <logger name="org.jctools" level="ERROR" />
    <logger name="io.micrometer" level="WARN" />
    <logger name="org.apache.catalina" level="WARN" />
    <logger name="org.apache.coyote" level="WARN" />

    <!-- Our app loggers — suppress Spring's startup messages from our main class -->
    <logger name="io.github.randomcodespace.iq.CodeIqApplication" level="WARN" />
    <logger name="io.github.randomcodespace.iq" level="INFO" />

    <!-- Indexing profile: minimal logging (CLI mode), plaintext -->
    <springProfile name="indexing">
        <root level="ERROR">
            <appender-ref ref="CONSOLE" />
        </root>
        <logger name="io.github.randomcodespace.iq" level="INFO" />
        <logger name="io.github.randomcodespace.iq.CodeIqApplication" level="WARN" />
    </springProfile>

    <!-- Serving profile: structured JSON for log aggregation -->
    <springProfile name="serving">
        <root level="WARN">
            <appender-ref ref="JSON" />
        </root>
        <logger name="io.github.randomcodespace.iq" level="INFO" />
    </springProfile>

    <!-- Default (no profile active) — plaintext -->
    <springProfile name="default">
        <root level="WARN">
            <appender-ref ref="CONSOLE" />
        </root>
        <logger name="io.github.randomcodespace.iq" level="INFO" />
        <logger name="io.github.randomcodespace.iq.CodeIqApplication" level="WARN" />
    </springProfile>

</configuration>
